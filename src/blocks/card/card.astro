---
import { Image } from "astro:assets";
import "./card.css";
const {
    imageUrl, alt
} = Astro.props
---

<div class="card">
    {
        imageUrl ? <Image
        src={imageUrl}
        alt={alt || imageUrl}
        loading={"lazy"}
        width={100}
        height={100}
    /> : ''
    }
    <div class="card__content">
        <slot/>
    </div>
</div>
